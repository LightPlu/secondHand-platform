# Spring profile
SPRING_PROFILES_ACTIVE=local

# PostgreSQL (docker-compose service name: postgres)
DB_URL=jdbc:postgresql://postgres:5432/secondhand_platform
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
HIBERNATE_FORMAT_SQL=true

# Redis (docker-compose service name: redis)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=CHANGE_ME_TO_32CHARS_OR_MORE_FOR_DOCKER
JWT_EXPIRATION=86400000

# Cloudflare R2
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

